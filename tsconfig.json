{
	"extends": "./.svelte-kit/tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"checkJs": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"sourceMap": true,
		"strict": false,
		"paths": {
			"$api/*": [
				"./src/lib/api/*"
			],
			"$stores/*": [
				"./src/lib/stores/*"
			],
			"$components/*": [
				"./src/lib/components/*"
			],
			"$types/*": [
				"./src/lib/types/*"
			],
			"$utils/*": [
				"./src/lib/utils/*"
			],
			"$offline/*": [
				"./src/lib/offline/*"
			]
		}
	}
}